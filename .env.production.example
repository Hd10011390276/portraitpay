# ============================================================
# PortraitPay AI — Production Environment Variables Template
# 复制此文件为 .env，填入真实值后使用
# ============================================================

# ─── Database ────────────────────────────────────────────────
# 推荐: Supabase / Neon PostgreSQL（均需开启 SSL）
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"

# ─── Core Auth ────────────────────────────────────────────────
AUTH_SECRET="GENERATE_WITH: openssl rand -base64 32"
AUTH_URL="https://portraitpayai.com"
NEXTAUTH_URL="https://portraitpayai.com"
NEXTAUTH_SECRET="GENERATE_WITH: openssl rand -base64 32"

# ─── OAuth ───────────────────────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."   # Stripe Dashboard → Webhooks → Endpoint secret
STRIPE_STUB="false"                 # ⚠️ 生产必须设为 false

# ─── Blockchain ─────────────────────────────────────────────
ETHEREUM_SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"
ETH_WALLET_PRIVATE_KEY="0x..."     # ⚠️ burner wallet，勿存主网资金
PORTRAIT_CERT_CONTRACT_ADDRESS="0x..."

# ─── IPFS ────────────────────────────────────────────────────
PINATA_API_KEY=""
PINATA_SECRET_API_KEY=""
PINATA_JWT=""

# ─── S3 / R2 ─────────────────────────────────────────────────
AWS_S3_BUCKET="portraitpay-uploads"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_ENDPOINT=""                    # Cloudflare R2 用: https://xxx.r2.cloudflarestorage.com

# ─── KYC ─────────────────────────────────────────────────────
KYC_PROVIDER="aliyun"              # aliyun | tencent | onfido | jumio

# 阿里云实人认证（生产）
KYC_ALIYUN_STUB="false"           # ⚠️ 生产必须设为 false
KYC_ALIYUN_AUTO_APPROVE="false"  # ⚠️ 生产必须设为 false
KYC_ALIYUN_ACCESS_KEY_ID=""
KYC_ALIYUN_ACCESS_KEY_SECRET=""
KYC_ALIYUN_REGION="cn-shanghai"
KYC_ALIYUN_APP_ID=""
KYC_ALIYUN_WEBHOOK_SECRET=""

# ─── AI ──────────────────────────────────────────────────────
OPENAI_API_KEY=""
